# Copie este arquivo para .env.local (raiz) ou frontend/.env.local e preencha.
# NUNCA commite valores reais.

# --- Supabase (frontend) ------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI (integrado via /api/chat) ----------------------------------------
# Usado pela API Route para chat com IA. Se nao configurar, funciona em modo
# fallback local (sem chamadas para OpenAI).
OPENAI_API_KEY=
# Modelo a usar (default: gpt-4o-mini para custo/velocidade otimos)
OPENAI_MODEL=gpt-4o-mini

# --- Banco (backend, uso futuro) ---------------------------------------------
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres
